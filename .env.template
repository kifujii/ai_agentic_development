# =============================================================================
# 受講者固有の設定
# =============================================================================
# PREFIX: AWSリソース名の接頭辞（受講者ごとにユニークな値を設定してください）
# 例: user01, tanaka, team-a など（英数字とハイフンのみ）
# 同一AWS環境で複数人が作業するため、リソース名の衝突を防ぐために必要です。
PREFIX=user01

# =============================================================================
# AWS認証情報
# =============================================================================
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_DEFAULT_REGION=ap-northeast-1

# Claude Code の設定は .claude/settings.local.json に記載されます。
# セットアップスクリプト（./scripts/setup_devspaces.sh）を実行すると自動生成されます。
# 詳細は docs/setup/CLAUDE_CODE_SETUP.md を参照してください。
